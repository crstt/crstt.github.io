---
import { profile } from '../data/content';

const links = [
  { label: 'Work', href: '#experience' },
  { label: 'Build', href: '#highlights' },
  { label: 'Stack', href: '#capabilities' },
  { label: 'Contact', href: '#contact' },
];
---

<header class="nav" data-nav>
  <div class="nav__inner shell">
    <a class="nav__brand" href="#top" aria-label="Back to top">
      <span class="nav__mark">MC</span>
      <span class="nav__name">{profile.name}</span>
    </a>

    <nav class="nav__links" aria-label="Primary">
      {links.map((l, i) => (
        <a href={l.href} class="nav__link">
          <span class="nav__idx">0{i + 1}</span>
          {l.label}
        </a>
      ))}
      <a href="/Matteo-Catalano-Resume.pdf" class="nav__link" download>
        <span class="nav__idx">↓</span>
        Résumé
      </a>
    </nav>

    <a class="nav__cta" href={`mailto:${profile.email}`}>
      <span>Get in touch</span>
      <span class="nav__cta-dot"></span>
    </a>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition: transform 0.5s var(--ease-out), background 0.4s ease, border-color 0.4s ease;
    border-bottom: 1px solid transparent;
    background: rgba(10, 10, 11, 0);
    backdrop-filter: blur(0px);
  }
  .nav.is-scrolled {
    background: rgba(10, 10, 11, 0.72);
    backdrop-filter: blur(14px);
    border-bottom-color: var(--line);
  }
  .nav.is-hidden {
    transform: translateY(-105%);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 4.6rem;
  }

  .nav__brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }
  .nav__mark {
    font-family: var(--font-display);
    font-size: 1.4rem;
    letter-spacing: 0.02em;
    color: var(--ink);
    background: var(--ember);
    width: 2.1rem;
    height: 2.1rem;
    display: grid;
    place-items: center;
    line-height: 1;
    padding-top: 0.18rem;
    clip-path: polygon(0 0, 100% 0, 100% 78%, 78% 100%, 0 100%);
  }
  .nav__name {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--paper-dim);
  }

  .nav__links {
    display: flex;
    gap: 1.8rem;
  }
  .nav__link {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--paper-dim);
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    transition: color 0.25s ease;
  }
  .nav__idx {
    color: var(--ember);
    font-size: 0.6rem;
  }
  .nav__link:hover {
    color: var(--paper);
  }

  .nav__cta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.55rem 1rem;
    border: 1px solid var(--line-strong);
    border-radius: 100px;
    transition: border-color 0.3s ease, color 0.3s ease;
  }
  .nav__cta-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--ember);
    box-shadow: 0 0 0 0 rgba(255, 77, 0, 0.6);
    animation: pulse 2.4s var(--ease-io) infinite;
  }
  .nav__cta:hover {
    border-color: var(--ember);
    color: var(--ember-hot);
  }

  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(255, 77, 0, 0.55); }
    70% { box-shadow: 0 0 0 9px rgba(255, 77, 0, 0); }
    100% { box-shadow: 0 0 0 0 rgba(255, 77, 0, 0); }
  }

  @media (max-width: 800px) {
    .nav__links,
    .nav__name { display: none; }
  }
</style>
