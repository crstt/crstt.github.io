---
import { stats } from '../data/content';
---

<section class="stats">
  <div class="shell stats__grid">
    {stats.map((s) => (
      <div class="stats__item" data-reveal>
        <span
          class="stats__num display"
          data-count={s.value}
          data-suffix={s.suffix}
          data-decimals={s.decimals ?? 0}
        >0{s.suffix}</span>
        <span class="stats__label">{s.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .stats {
    padding-block: clamp(3rem, 7vw, 6rem);
    border-block: 1px solid var(--line);
    background:
      linear-gradient(180deg, rgba(255, 77, 0, 0.03), transparent 60%),
      var(--ink-soft);
  }
  .stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1.5rem, 4vw, 3rem);
  }
  .stats__item {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .stats__num {
    font-size: clamp(3.2rem, 7vw, 6.5rem);
    color: var(--paper);
    line-height: 0.9;
  }
  .stats__label {
    font-size: 0.92rem;
    color: var(--paper-dim);
    line-height: 1.4;
    max-width: 22ch;
  }

  @media (max-width: 800px) {
    .stats__grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
