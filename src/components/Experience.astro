---
import { experience } from '../data/content';
---

<section class="exp" id="experience">
  <div class="shell">
    <div class="exp__head">
      <span class="eyebrow" data-reveal>Experience</span>
      <h2 class="exp__title display" data-reveal>Where I’ve<br /><span class="exp__title-em">shipped</span></h2>
    </div>

    <div class="exp__body">
      <ol class="exp__list">
        {experience.map((job) => (
          <li class="exp__job" data-reveal data-theme={JSON.stringify(job.theme)}>
            <div class="exp__no mono">{job.no}</div>
            <div class="exp__main">
              <div class="exp__row">
                <h3 class="exp__company display">
                  {job.company}
                  {job.current && <span class="exp__live">Now</span>}
                </h3>
                <span class="exp__period mono">{job.period}</span>
              </div>
              <p class="exp__role">{job.role} <span class="exp__loc">— {job.location}</span></p>
              <ul class="exp__bullets">
                {job.bullets.map((b) => (
                  <li set:html={b} />
                ))}
              </ul>
              <div class="exp__stack">
                {job.stack.map((t) => <span class="exp__tag">{t}</span>)}
              </div>
            </div>
          </li>
        ))}
      </ol>

      <!-- Morphing point-cloud: one glowing sculpture per job (see morph-cloud.ts) -->
      <div class="exp__cloudwrap" aria-hidden="true">
        <div class="exp__cloud" data-cloud>
          <canvas data-cloud-canvas></canvas>
          <span class="exp__cloud-label mono" data-cloud-label></span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .exp {
    padding-block: clamp(5rem, 12vw, 11rem);
  }
  .exp__head {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    margin-bottom: clamp(3rem, 7vw, 6rem);
  }
  .exp__title {
    font-size: clamp(3rem, 9vw, 8rem);
  }
  .exp__title-em {
    color: transparent;
    -webkit-text-stroke: 1.5px var(--ember);
  }

  .exp__body {
    display: grid;
    grid-template-columns: 1fr;
  }
  .exp__cloudwrap {
    display: none;
  }
  @media (min-width: 1100px) and (prefers-reduced-motion: no-preference) {
    .exp__body {
      grid-template-columns: minmax(0, 1fr) clamp(320px, 30vw, 520px);
      gap: clamp(2rem, 4vw, 4rem);
      align-items: stretch;
    }
    .exp__cloudwrap {
      display: block;
      position: relative;
    }
    .exp__cloud {
      position: sticky;
      top: 0;
      height: 100svh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1.4rem;
    }
    .exp__cloud canvas {
      width: 100%;
      height: min(72svh, 100%);
      flex: 0 1 auto;
    }
    .exp__cloud-label {
      color: var(--paper-faint);
      transition: opacity 0.22s ease, transform 0.22s ease;
      text-align: center;
    }
    .exp__cloud-label.is-swap {
      opacity: 0;
      transform: translateY(6px);
    }
  }

  .exp__list {
    list-style: none;
    min-width: 0;
  }
  .exp__job {
    display: grid;
    grid-template-columns: 5rem 1fr;
    gap: 1.5rem;
    padding-block: clamp(2rem, 4vw, 3.4rem);
    border-top: 1px solid var(--line);
    transition: background 0.4s ease;
  }
  .exp__job:last-child { border-bottom: 1px solid var(--line); }
  .exp__job:hover { background: linear-gradient(90deg, color-mix(in srgb, var(--ember) 6%, transparent), transparent 40%); }

  .exp__no {
    color: var(--ember);
    font-size: 0.9rem;
    padding-top: 0.6rem;
  }

  .exp__row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .exp__company {
    font-size: clamp(1.8rem, 4vw, 3.2rem);
    line-height: 1;
    display: inline-flex;
    align-items: center;
    gap: 1rem;
  }
  .exp__live {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    color: var(--ink);
    background: #4ade80;
    padding: 0.25rem 0.55rem;
    border-radius: 100px;
    transform: translateY(-0.4em);
  }
  .exp__period {
    color: var(--paper-faint);
    font-size: 0.72rem;
    white-space: nowrap;
  }
  .exp__role {
    margin-top: 0.7rem;
    color: var(--paper);
    font-weight: 500;
    font-size: 1.05rem;
  }
  .exp__loc { color: var(--paper-faint); font-weight: 400; }

  .exp__bullets {
    margin-top: 1.3rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    max-width: 72ch;
    list-style: none;
  }
  .exp__bullets li {
    color: var(--paper-dim);
    font-size: 1rem;
    line-height: 1.55;
    padding-left: 1.4rem;
    position: relative;
  }
  .exp__bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 7px;
    height: 1px;
    background: var(--ember);
  }

  .exp__stack {
    margin-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .exp__tag {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--paper-dim);
    border: 1px solid var(--line-strong);
    padding: 0.35rem 0.7rem;
    border-radius: 100px;
  }

  @media (max-width: 700px) {
    .exp__job { grid-template-columns: 1fr; gap: 0.5rem; }
    .exp__no { padding-top: 0; }
  }
</style>
